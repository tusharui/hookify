generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String           @id @default(cuid())
  clerkId     String           @unique
  email       String?
  name        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  generations HookGeneration[]
}

model HookGeneration {
  id        String     @id @default(cuid())
  userId    String
  niche     String
  input     String?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     HookItem[]

  @@index([userId])
  @@index([niche])
}

model HookItem {
  id           String         @id @default(cuid())
  generationId String
  content      String
  type         ContentType
  score        Int?
  isFavorite   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  generation   HookGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([type])
}

enum ContentType {
  HOOK
  TWEET
  REEL
  CAPTION
}
